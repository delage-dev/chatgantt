# ChatGantt backend environment variables
# Copy this file to .env and fill in real values before running.

# ---------------------------------------------------------------------------
# LiveKit Cloud
# Sign up at https://cloud.livekit.io, create a project, then copy these from
# Settings → Keys. Required by both the api service (token minting) and the
# agent service (worker registration + room connection).
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-api-secret

# ---------------------------------------------------------------------------
# Anthropic
# Used by the LiveKit voice agent for the Claude LLM.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Notion
# Notion credentials are NOT environment variables in this app — they flow
# per-request via HTTP headers from the voice pane and the reverse proxy:
#
#   X-Provider: notion
#   Authorization: Bearer secret_xxx           (Notion integration token)
#   X-Project: <tasks_data_source_id>
#   X-Notion-Blockers-Source: <blockers_data_source_id>
#
# Run `uv run python -m scripts.provision_notion --help` (see backend/scripts/README.md)
# to create the Tasks + Blockers data sources and print these IDs.
# ---------------------------------------------------------------------------
